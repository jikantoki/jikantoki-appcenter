# WebPush Configuration
# WebPush用の公開鍵（https://web-push-codelab.glitch.me/ で生成）
NUXT_WEBPUSH_PUBLICKEY=

# WebPush用の秘密鍵
NUXT_WEBPUSH_PRIVATEKEY=

# API Configuration
# API ID（デフォルトは "default"）
NUXT_API_ID=default

# API トークン（PHPサーバーで生成）
NUXT_API_TOKEN=

# API アクセスキー（PHPサーバーで生成）
NUXT_API_ACCESSKEY=

# API サーバーのホスト（例: https://api.example.com）
NUXT_API_HOST=
